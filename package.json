{
  "name": "@gnolith/waystone",
  "version": "0.2.0",
  "description": "The accessible human interface and extension surface for Gnolith research Sites.",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gnolith/waystone.git"
  },
  "homepage": "https://github.com/gnolith/waystone#readme",
  "bugs": {
    "url": "https://github.com/gnolith/waystone/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    },
    "./site": {
      "types": "./dist/site.d.ts",
      "import": "./dist/site.js"
    },
    "./fixtures": {
      "types": "./dist/fixtures.d.ts",
      "import": "./dist/fixtures.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "docs/accessibility.md",
    "docs/api-client.md",
    "docs/codex-sites.md",
    "docs/components.md",
    "docs/plugins.md",
    "docs/search-content-operations.md",
    "docs/releasing.md",
    "docs/styling.md",
    "docs/taproot-dependencies.md",
    "docs/troubleshooting.md",
    "docs/upgrades.md",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/build-css.mjs",
    "check": "npm run check:package && npm run consumer:check",
    "check:package": "npm run format:check && npm run lint && npm run typecheck && npm run security:check && npm run test:coverage && npm run build && npm run verify:package && npm run boundary:check && npm run budgets",
    "boundary:check": "node scripts/check-consumer-boundary.mjs",
    "consumer:check": "node scripts/check-consumer.mjs && node scripts/check-declaration-consumer.mjs && node scripts/check-taproot-contract.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src test",
    "release:check": "node scripts/release-check.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "verify:package": "node scripts/verify-package.mjs",
    "budgets": "node scripts/check-budgets.mjs",
    "security:check": "npm audit --audit-level=high && npm audit --omit=dev --audit-level=high && npm audit --package-lock-only --prefix examples/codex-site-canary --audit-level=high && npm audit --package-lock-only --prefix examples/codex-site-canary --omit=dev --audit-level=high",
    "prepack": "npm run check:package"
  },
  "peerDependencies": {
    "@gnolith/taproot": ">=0.3.0 <0.5.0",
    "@types/react": ">=19 <20",
    "react": ">=19 <20",
    "react-dom": ">=19 <20"
  },
  "peerDependenciesMeta": {
    "@gnolith/taproot": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "npm@11.9.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.1.6",
    "@vitest/coverage-v8": "^3.2.4",
    "axe-core": "^4.10.3",
    "esbuild": "^0.25.8",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^26.1.0",
    "prettier": "^3.9.5",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "gnolith",
    "research",
    "wikibase",
    "sparql",
    "react",
    "codex-sites"
  ],
  "license": "MIT"
}
